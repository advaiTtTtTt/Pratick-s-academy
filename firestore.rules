rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Subjects & lectures: any authenticated user can read
    match /subjects/{subjectId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /lectures/{lectureId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Notifications: anyone can read, admins can write
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Alerts: anyone can read, admins can write
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users: can read own doc, admin can read and write all
    match /users/{userId} {
      allow read: if request.auth != null 
        && (request.auth.uid == userId 
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // ALLOW students to create their own document (but force role to 'student')
      // ALSO allow Pratik and Advait to create an admin document
      allow create: if request.auth != null 
        && request.auth.uid == userId
        && (request.resource.data.role == 'student' || (request.resource.data.role == 'admin' && request.resource.data.email in ['pratikrajguru45@gmail.com', '2023.advait.daware@ves.ac.in']));
        
      // ONLY admins can update/delete users
      // ALLOW students to update their own profile (but prevent changing role)
      // Admins can update any profile
      allow update: if request.auth != null 
        && (
          (request.auth.uid == userId && request.resource.data.role == resource.data.role)
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
        
      // ONLY admins can delete users
      allow delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
